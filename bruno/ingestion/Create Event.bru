meta {
  name: Create Event
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/events
  body: json
  auth: none
}

body:json {
  {
    "id": "evt-1",
    "session_id": "sess-1",
    "type": "user.signup",
    "message": "hello, world",
    "timestamp": "2026-07-15T12:00:00Z"
  }
}

assert {
  res.status: eq 202
}

docs {
  Publishes a valid event. The service validates the payload, publishes it to the
  `events` Kafka topic, and responds with 202 Accepted — persistence is asynchronous.
}
