# Ingestion service configuration — all variables are required.
# Copy to .env and adjust for your environment.

# Log level: debug, info, warn, or error
LOG_LEVEL=info

# Address the HTTP server listens on
LISTEN_ADDR=:8080

# Address the gRPC server (health check endpoint) listens on
GRPC_ADDR=:9090

# Comma-separated list of Kafka broker addresses
KAFKA_BROKERS=localhost:9092

# Kafka topic events are published to
KAFKA_TOPIC=events

# Upper bound for a single publish call; exceeding it returns 503 to the client
PUBLISH_TIMEOUT=2s

# Grace period for in-flight requests on shutdown
SHUTDOWN_TIMEOUT=10s
