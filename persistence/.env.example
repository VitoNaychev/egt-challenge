# Persistence service configuration — all variables are required.
# Copy to .env and adjust for your environment.

# Log level: debug, info, warn, or error
LOG_LEVEL=info

# Comma-separated list of Kafka broker addresses
KAFKA_BROKERS=localhost:9092

# Kafka topic events are consumed from
KAFKA_TOPIC=events

# Consumer group ID; offsets are tracked per group
KAFKA_GROUP_ID=persistence

# PostgreSQL connection string
DATABASE_URL=postgres://egt:events@localhost:5432/challenge?sslmode=disable
